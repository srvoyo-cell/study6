== Поиск денежных сумм

#listing("2.2", "Регулярное выражение для денежных сумм")[
```python
MONEY_RE = re.compile(
    r"[\$€£]?\s*\d[\d\s,.]+"
    r"(?:млн|млрд|тыс\.?|миллиона|миллиард[а-я]*)?"
    r"\s*(?:руб(?:лей|ля)?\.?|долларов?|долл\.?|евро|копеек)?",
    re.IGNORECASE,
)
CURRENCY = {"руб","долл","доллар","евро","копеек",
            "млн","млрд","тыс","миллион","миллиард"}

def find_money_in_titles(df):
    results = []
    for title in df["title"]:
        t = title.replace("\xa0", " ")
        for m in MONEY_RE.finditer(t):
            context = t[max(0, m.start()-15) : m.end()+20].lower()
            if any(w in context for w in CURRENCY):
                results.append((t, m.group().strip()))
    return results
```
]

